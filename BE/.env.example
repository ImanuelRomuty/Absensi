NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Local embedded Postgres (pnpm db:pg) OR Neon connection string for cloud:
DATABASE_URL=postgresql://masarif:masarif@127.0.0.1:5433/masarif?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

LOG_LEVEL=info

# Comma-separated Vercel (or local) origins. Leave empty in local dev to allow all.
# Example production: https://masarif-web.vercel.app,http://localhost:5173
WEB_ORIGIN=
