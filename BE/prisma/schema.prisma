generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  HR_ADMIN
  SUPER_ADMIN
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  role         Role           @default(EMPLOYEE)
  employeeId   String?        @unique
  employee     Employee?      @relation(fields: [employeeId], references: [id])
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]
  approvalsRequested Approval[] @relation("ApprovalRequester")
  approvalsReviewed  Approval[] @relation("ApprovalReviewer")
}

model Employee {
  id           String             @id @default(cuid())
  name         String
  employeeCode String             @unique
  department   String?
  managerId    String?
  manager      Employee?          @relation("EmployeeManager", fields: [managerId], references: [id])
  reports      Employee[]         @relation("EmployeeManager")
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User?
  locations    EmployeeLocation[]
  attendances  Attendance[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Location {
  id           String             @id @default(cuid())
  name         String
  latitude     Float
  longitude    Float
  radiusMeters Int                @default(100)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  employees    EmployeeLocation[]
  attendances  Attendance[]
}

model EmployeeLocation {
  employeeId String
  locationId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([employeeId, locationId])
  @@index([locationId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String?
  actor      User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum AttendanceType {
  CLOCK_IN
  CLOCK_OUT
}

model Attendance {
  id              String         @id @default(cuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type            AttendanceType
  latitude        Float
  longitude       Float
  accuracyMeters  Float?
  locationId      String?
  location        Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)
  idempotencyKey  String         @unique
  isLate          Boolean        @default(false)
  isEarly         Boolean        @default(false)
  recordedAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())

  @@index([employeeId, recordedAt])
  @@index([recordedAt])
}

enum ApprovalType {
  ATTENDANCE_CORRECTION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Approval {
  id          String         @id @default(cuid())
  type        ApprovalType
  status      ApprovalStatus @default(PENDING)
  requesterId String
  requester   User           @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewerId  String?
  reviewer    User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  note        String?
  decisionNote String?
  payload     Json
  entityType  String?
  entityId    String?
  createdAt   DateTime       @default(now())
  decidedAt   DateTime?

  @@index([status, createdAt])
  @@index([requesterId])
  @@index([type, status])
}
